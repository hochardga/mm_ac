# Local development defaults to embedded PGlite.
DATABASE_DRIVER=pglite
# Optional locally for pglite mode; required when DATABASE_DRIVER=postgres.
# DATABASE_URL=postgres://postgres:postgres@localhost:5432/ashfall_collective
# REQUIRED: Generate a secure secret (for example: openssl rand -base64 32).
# Do not deploy with placeholder values like "replace-me".
NEXTAUTH_SECRET=replace-me
# Local: http://127.0.0.1:3000
# Hosted: https://<your-project>.vercel.app
NEXTAUTH_URL=http://127.0.0.1:3000

# Hosted Vercel deployments must switch to shared Postgres:
# DATABASE_URL=postgres://user:password@host:5432/database
# POSTGRES_URL=postgres://user:password@host:5432/database
# DATABASE_DRIVER=postgres
# NEXTAUTH_URL=https://<your-project>.vercel.app
